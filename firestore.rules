rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if current user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ─── Users ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ─── Stories ────────────────────────────────────────────────
    // Publicly readable so stories list and detail load server-side.
    match /stories/{storyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
      allow delete: if request.auth != null && isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          resource.data.authorId == request.auth.uid || isAdmin()
        );
        allow delete: if request.auth != null && isAdmin();
      }
    }

    // ─── Submitted Dilemmas ─────────────────────────────────────
    // Approved dilemmas are publicly readable (server actions run without auth context).
    match /submittedDilemmas/{dilemmaId} {
      allow read: if resource.data.status == 'approved' ||
                     (request.auth != null && (
                       request.auth.uid == resource.data.authorId || isAdmin()
                     ));
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId || isAdmin()
      );
    }

    // ─── Debates ────────────────────────────────────────────────
    // Publicly readable so the debate list loads server-side.
    match /debates/{debateId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
      allow delete: if request.auth != null && isAdmin();

      match /arguments/{argumentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && (
          resource.data.authorId == request.auth.uid || isAdmin()
        );
        allow delete: if request.auth != null && isAdmin();
      }

      match /votes/{voteId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null && resource.data.userId == request.auth.uid;
        allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      }
    }

    // ─── Chat Sessions ─────────────────────────────────────────
    // Reads are open because server actions run without auth context;
    // queries are always filtered by userId in application code.
    match /chatSessions/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── User Progress ─────────────────────────────────────────
    match /userProgress/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;

      match /impactScores/{scoreId} {
        allow read: if true;
        allow create: if true;
      }
    }

    // ─── Bookmarks ──────────────────────────────────────────────
    match /bookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    // ─── Organizations ──────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.memberRoles[request.auth.uid] == 'owner' ||
        resource.data.memberRoles[request.auth.uid] == 'leader'
      );

      match /invites/{inviteId} {
        allow read: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members
        );
        allow create, update: if request.auth != null && (
          get(/databases/$(database)/documents/organizations/$(orgId)).data.memberRoles[request.auth.uid] in ['owner', 'leader']
        );
      }
    }

    // ─── Workshops ──────────────────────────────────────────────
    match /workshops/{workshopId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.hostId == request.auth.uid ||
        request.auth.uid in resource.data.participantIds ||
        isAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.hostId == request.auth.uid || isAdmin()
      );
    }

    // ─── Curricula ──────────────────────────────────────────────
    match /curricula/{curriculumId} {
      allow read: if request.auth != null && (
        resource.data.isPublic == true ||
        resource.data.creatorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );

      match /enrollments/{userId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          get(/databases/$(database)/documents/curricula/$(curriculumId)).data.creatorId == request.auth.uid
        );
        allow create, update: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── Philosophers ───────────────────────────────────────────
    match /philosophers/{philosopherId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // ─── Classrooms ─────────────────────────────────────────────
    match /classrooms/{classroomId} {
      allow read: if request.auth != null && (
        resource.data.teacherId == request.auth.uid ||
        request.auth.uid in resource.data.studentIds ||
        isAdmin()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.teacherId == request.auth.uid || isAdmin()
      );
      allow delete: if request.auth != null && (
        resource.data.teacherId == request.auth.uid || isAdmin()
      );

      match /studentProgress/{studentId} {
        allow read: if request.auth != null && (
          request.auth.uid == studentId ||
          get(/databases/$(database)/documents/classrooms/$(classroomId)).data.teacherId == request.auth.uid
        );
        allow create, update: if request.auth != null && request.auth.uid == studentId;
      }
    }

    // ─── Communities ────────────────────────────────────────────
    // Server actions call these; auth enforced in application code.
    match /communities/{communityId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Community Invites ──────────────────────────────────────
    match /communityInvites/{inviteId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Subscriptions ──────────────────────────────────────────
    // Server actions call these; auth enforced in application code.
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Licenses ───────────────────────────────────────────────
    match /licenses/{licenseId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Seat Assignments ───────────────────────────────────────
    match /seatAssignments/{seatId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
