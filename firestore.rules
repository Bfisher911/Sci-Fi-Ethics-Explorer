
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules for the 'users' collection
    match /users/{userId} {
      // Allow a user to READ their own profile document
      // This is essential for the profile page to load.
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow a user to CREATE their own profile document (e.g., during sign-up)
      // The 'uid' field in the document data must match their authenticated UID.
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.data.uid == request.auth.uid;

      // Allow a user to UPDATE their own profile document
      allow update: if request.auth != null && request.auth.uid == userId;

      // Optionally, allow delete if needed, though typically users don't delete their own accounts this way.
      // allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for /submittedDilemmas/{dilemmaId}
    match /submittedDilemmas/{dilemmaId} {
      // Allow read if dilemma is approved, or if the requester is the author
      allow read: if (resource.data.status == 'approved') || 
                     (request.auth != null && request.auth.uid == resource.data.authorId);
      // Allow authenticated users to create dilemmas
      allow create: if request.auth != null && 
                       request.resource.data.authorId == request.auth.uid &&
                       request.resource.data.status == 'pending'; // Ensure status is pending on create
      // Allow author to update their own pending dilemma, or admin to update any
      allow update: if request.auth != null && 
                       ( (request.auth.uid == resource.data.authorId && resource.data.status == 'pending') || 
                         (request.auth.token.isAdmin == true) ); // Assuming an isAdmin custom claim for admins
      // Allow admin to delete
      allow delete: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // 🔁 PATCH: Add Organization access rules (BF 2025-06-06)
    match /organizations/{orgId} {
      // Allow an authenticated user to create an organization.
      // Ensure the document being created correctly lists the creator as owner and member.
      allow create: if request.auth != null &&
                       request.resource.data.ownerId == request.auth.uid &&
                       request.auth.uid in request.resource.data.members &&
                       request.resource.data.memberRoles[request.auth.uid] == 'owner';

      // Allow members to read the organization document they belong to.
      // This can be based on the `members` array in the document.
      // OR, more securely and efficiently for queries, based on custom claims.
      allow read: if request.auth != null && 
                     ( (request.auth.uid in resource.data.members) || 
                       (request.auth.token.teamId == orgId) ); // Check custom claim

      // Allow updates only by users who are 'owner' or 'leader' for this specific orgId.
      // This requires custom claims (teamId and role) to be set correctly.
      allow update: if request.auth != null &&
                       request.auth.token.teamId == orgId &&
                       request.auth.token.role in ['owner', 'leader'];

      // Only the owner can delete the organization.
      allow delete: if request.auth != null &&
                       request.auth.token.teamId == orgId &&
                       request.auth.token.role == 'owner' &&
                       request.auth.uid == resource.data.ownerId; // Double check ownerId field

      // Subcollections: Rules will be more granular in later phases
      match /modules/{moduleId} {
        // Members of the team can read modules.
        allow read: if request.auth != null && request.auth.token.teamId == orgId;
        // Only owners or leaders of the team can create, update, or delete modules.
        allow write: if request.auth != null &&
                        request.auth.token.teamId == orgId &&
                        request.auth.token.role in ['owner', 'leader'];
      }
      match /assignments/{assignmentId} {
        // For now, similar to modules: leaders/owners manage, members might read if assigned.
        // This will need refinement based on assignment structure.
        allow read: if request.auth != null && request.auth.token.teamId == orgId; // Broad read for members
        allow write: if request.auth != null &&
                        request.auth.token.teamId == orgId &&
                        request.auth.token.role in ['owner', 'leader'];
      }
      match /chats/{chatId} {
        // Basic read for team members
        allow read: if request.auth != null && request.auth.token.teamId == orgId;
        // Placeholder for write, typically any team member can write messages
        allow write: if request.auth != null && request.auth.token.teamId == orgId; 
        match /messages/{messageId} {
            allow read: if request.auth != null && request.auth.token.teamId == orgId;
            allow create: if request.auth != null && 
                             request.auth.token.teamId == orgId &&
                             request.resource.data.userId == request.auth.uid; // Message author must be current user
        }
      }
      match /analytics/{analyticsDocId} {
         // Leaders/owners can read analytics.
         allow read: if request.auth != null &&
                        request.auth.token.teamId == orgId &&
                        request.auth.token.role in ['owner', 'leader'];
         // System or trusted functions might write analytics, or team members for specific interaction logs.
         // For interaction logs by members:
         allow create: if request.auth != null && 
                          request.auth.token.teamId == orgId && 
                          request.resource.data.userId == request.auth.uid;
      }
    }
    // 🔁 END PATCH
  }
}
