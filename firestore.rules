rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if current user is admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ─── Users ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ─── Stories ────────────────────────────────────────────────
    // Writes go through server actions which run without Firebase auth
    // context; authorship is enforced in application code.
    match /stories/{storyId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }
    }

    // ─── Submitted Dilemmas ─────────────────────────────────────
    match /submittedDilemmas/{dilemmaId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Debates ────────────────────────────────────────────────
    match /debates/{debateId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /arguments/{argumentId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }

      match /votes/{voteId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }
    }

    // ─── Chat Sessions ─────────────────────────────────────────
    // Reads are open because server actions run without auth context;
    // queries are always filtered by userId in application code.
    match /chatSessions/{sessionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── User Progress ─────────────────────────────────────────
    match /userProgress/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;

      match /impactScores/{scoreId} {
        allow read: if true;
        allow create: if true;
      }
    }

    // ─── Bookmarks ──────────────────────────────────────────────
    match /bookmarks/{bookmarkId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    // ─── Organizations ──────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.members;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.memberRoles[request.auth.uid] == 'owner' ||
        resource.data.memberRoles[request.auth.uid] == 'leader'
      );

      match /invites/{inviteId} {
        allow read: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members
        );
        allow create, update: if request.auth != null && (
          get(/databases/$(database)/documents/organizations/$(orgId)).data.memberRoles[request.auth.uid] in ['owner', 'leader']
        );
      }
    }

    // ─── Workshops ──────────────────────────────────────────────
    match /workshops/{workshopId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /messages/{messageId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }
    }

    // ─── Curricula ──────────────────────────────────────────────
    match /curricula/{curriculumId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /enrollments/{userId} {
        allow read: if true;
        allow create, update: if true;
      }
    }

    // ─── Philosophers ───────────────────────────────────────────
    match /philosophers/{philosopherId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ─── Classrooms ─────────────────────────────────────────────
    match /classrooms/{classroomId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /studentProgress/{studentId} {
        allow read: if true;
        allow create, update: if true;
      }
    }

    // ─── Ethical Theories (seeded reference data) ──────────────
    match /ethicalTheories/{theoryId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ─── User Badges ───────────────────────────────────────────
    match /userBadges/{userId} {
      allow read: if true;
      allow create, update: if true;
    }

    // ─── Notifications ─────────────────────────────────────────
    // Server actions create and query these; queries always filter by userId.
    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Saved Analyses ────────────────────────────────────────
    match /analyses/{analysisId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Saved Perspectives ────────────────────────────────────
    match /perspectives/{perspectiveId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Content Versions ──────────────────────────────────────
    match /contentVersions/{versionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Audit Log ─────────────────────────────────────────────
    match /auditLog/{entryId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    // ─── Quizzes ───────────────────────────────────────────────
    match /quizzes/{quizId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // ─── Quiz Attempts ─────────────────────────────────────────
    match /quizAttempts/{attemptId} {
      allow read: if true;
      allow create, update: if true;
    }

    // ─── Curriculum Progress ───────────────────────────────────
    // Composite ID: {userId}_{curriculumId}
    match /curriculumProgress/{progressId} {
      allow read: if true;
      allow create, update: if true;
    }

    // ─── Certificates ──────────────────────────────────────────
    match /certificates/{certId} {
      allow read: if true;
      allow create, update: if true;
    }

    // ─── Message Threads ───────────────────────────────────────
    match /messageThreads/{threadId} {
      allow read: if true;
      allow create, update: if true;

      match /messages/{messageId} {
        allow read: if true;
        allow create, update: if true;
      }
    }

    // ─── User Blocks ───────────────────────────────────────────
    // Document ID is the blocker's UID.
    match /userBlocks/{userId} {
      allow read: if true;
      allow create, update: if true;
    }

    // ─── Community Contributions ───────────────────────────────
    // Server actions enforce community membership in app code.
    match /communityContributions/{contributionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }
    }

    // ─── Communities ────────────────────────────────────────────
    // Server actions call these; auth enforced in application code.
    match /communities/{communityId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Community Invites ──────────────────────────────────────
    match /communityInvites/{inviteId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Subscriptions ──────────────────────────────────────────
    // Server actions call these; auth enforced in application code.
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Licenses ───────────────────────────────────────────────
    match /licenses/{licenseId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // ─── Seat Assignments ───────────────────────────────────────
    match /seatAssignments/{seatId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}
