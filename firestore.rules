
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Existing rules (if any) would be here.
    // For example, if you had rules for submittedDilemmas:
    // match /submittedDilemmas/{dilemmaId} {
    //   allow read: if resource.data.status == 'approved' || request.auth.uid == resource.data.authorId;
    //   allow create: if request.auth != null;
    // }

    // 🔁 PATCH: user profile access (BF 2025-06-06)
    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.uid == request.auth.uid;
    }
    // 🔁 END PATCH
  }
}
