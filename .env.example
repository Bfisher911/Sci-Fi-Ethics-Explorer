# ─── Sci-Fi Ethics Explorer — environment template ─────────────────
# Copy this file to .env.local for local dev (or paste these names into
# Netlify env vars for the deployed site). Anything prefixed with
# NEXT_PUBLIC_ ships in the client bundle — never put secrets there.

# ─── Public site URL ───────────────────────────────────────────────
# Used by metadataBase, OG tags, sitemap, robots.txt, and any
# absolute-URL emails. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.scifiethicsexplorer.com

# ─── Firebase (client SDK) ─────────────────────────────────────────
# All values are pulled from your Firebase project's web app config.
# These are public by design (Firebase auth + Firestore rules are the
# real gate, not these keys).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin (server-only) ──────────────────────────────────
# Used by API route handlers that need to verify Firebase ID tokens
# (e.g. /api/submit-dilemma). Generate from Firebase Console →
# Project Settings → Service Accounts → "Generate new private key".
# Paste the JSON as a single line, escaping newlines as \n.
# Optional in dev — if missing, the API endpoints that require server
# auth will reject all requests with 503.
FIREBASE_ADMIN_CREDENTIALS=
FIREBASE_PROJECT_ID=

# ─── Google Generative AI (Gemini) ─────────────────────────────────
# Used by all Genkit flows (compare-perspectives, ethical-counselor,
# generate-quiz, etc.). One of these will be picked up by the
# googleAI provider.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GENAI_API_KEY=

# ─── Stripe (payments) ─────────────────────────────────────────────
# STRIPE_SECRET_KEY: sk_live_... in production, sk_test_... in dev.
# STRIPE_WEBHOOK_SECRET: whsec_... — issued by Stripe when you create
# the webhook endpoint pointing at /api/webhooks/stripe.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY: only required if you do
# client-side checkout sessions (we use server-redirect right now).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Resend (email) ────────────────────────────────────────────────
# Used by the weekly digest cron and any future transactional emails.
# When RESEND_API_KEY is missing, sendEmail simulates and logs to
# stderr — the app keeps working.
RESEND_API_KEY=
EMAIL_FROM='Sci-Fi Ethics Explorer <noreply@scifiethicsexplorer.com>'
# RESEND_FROM=  # legacy alias — only one of EMAIL_FROM / RESEND_FROM is needed

# ─── Cron auth ─────────────────────────────────────────────────────
# A long random string that scheduled jobs (Netlify Scheduled Functions
# or external scheduler) pass as the Authorization: Bearer header to
# /api/cron/digest. Without it set, the cron endpoint refuses to run.
CRON_SECRET=

# ─── Sentry (error tracking) ───────────────────────────────────────
# Optional — when SENTRY_DSN is missing, the Sentry shim is a no-op.
# DSN is found at Sentry → Settings → Projects → Client Keys (DSN).
# NEXT_PUBLIC_SENTRY_DSN is the same value, exposed to the browser.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# SENTRY_AUTH_TOKEN=  # only if uploading source maps in CI
